    "test": "bun test",
    "check": "biome check . && tsc --noEmit && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@onrails/result": "^0.4.0",
    "ts-pattern": "^5.9.0"
  }
}
