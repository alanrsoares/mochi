{
  "name": "mochi",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "mochi": "src/cli.ts"
  },
  "scripts": {
    "mochi": "bun src/cli.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build:ext": "bun scripts/build-extension.mjs",
    "loc": "bun scripts/find-long-files.ts",
    "gen:prelude": "bun scripts/gen-prelude.ts",
    "gen:runtime": "bun scripts/gen-runtime.ts",
    "bootstrap:tsc": "bun scripts/bootstrap-tsc.ts",
    "fmt:al": "bun scripts/fmt-al.ts",
    "fmt:check": "bun scripts/fmt-al.ts --check",
    "fixpoint": "bun scripts/fixpoint.ts",
    "clean": "bun scripts/clean.ts",
    "check": "biome check . && tsc --noEmit && bun run --filter '*' check && bun run fmt:check && bun test"
  },
  "workspaces": [
    "editors/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "latest",
    "esbuild": "^0.28.1",
    "fast-check": "^4.9.0",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@onrails/maybe": "^0.2.3",
    "@onrails/pattern": "^0.3.2",
    "@onrails/result": "^0.4.0"
  },
  "patchedDependencies": {
    "@onrails/pattern@0.3.2": "patches/@onrails%2Fpattern@0.3.2.patch"
  }
}
