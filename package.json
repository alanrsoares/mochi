{
  "name": "alang",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": { "alang": "src/cli.ts" },
  "scripts": {
    "alang": "bun src/cli.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
