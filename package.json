{
  "name": "alang",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "alang": "src/cli.ts"
  },
  "scripts": {
    "alang": "bun src/cli.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build:ext": "bun scripts/build-extension.mjs",
    "loc": "bun scripts/find-long-files.ts",
    "check": "biome check . && tsc --noEmit && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "latest",
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.28.1",
    "fast-check": "^4.9.0",
    "vscode-languageclient": "^10.1.0",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@onrails/pattern": "^0.3.2",
    "@onrails/result": "^0.4.0",
    "ts-pattern": "^5.9.0"
  },
  "patchedDependencies": {
    "@onrails/pattern@0.3.2": "patches/@onrails%2Fpattern@0.3.2.patch"
  }
}
