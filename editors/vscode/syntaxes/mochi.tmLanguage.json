{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "mochi",
  "scopeName": "source.mochi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#braces" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#namespaces" },
    { "include": "#types" },
    { "include": "#constructors" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.mochi",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.mochi",
          "match": "//.*$"
        }
      ]
    },
    "braces": {
      "comment": "Balance {…} so ${ switch n { … } } holes close on the right brace",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.block.begin.mochi" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.block.end.mochi" }
      },
      "patterns": [{ "include": "$self" }]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mochi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mochi",
              "match": "\\\\."
            },
            {
              "comment": "ADR 0023 — ${expr} holes; escape rule above eats \\${ first",
              "name": "meta.interpolation.mochi",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.mochi" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.mochi" }
              },
              "contentName": "source.mochi.embedded",
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "let binding — highlight the bound name",
          "match": "\\b(let)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.mochi" },
            "2": { "name": "entity.name.function.mochi" }
          }
        },
        {
          "comment": "type declaration — highlight the type name",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.mochi" },
            "2": { "name": "entity.name.type.mochi" }
          }
        },
        {
          "comment": "extern declaration — highlight the external name",
          "match": "\\b(extern)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.mochi" },
            "2": { "name": "entity.name.function.mochi" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mochi",
          "match": "\\b(switch|import|export|in|when)\\b"
        },
        {
          "name": "keyword.declaration.mochi",
          "match": "\\b(let|type|extern)\\b"
        }
      ]
    },
    "namespaces": {
      "patterns": [
        {
          "name": "support.class.namespace.mochi",
          "match": "\\b(Array|List|Set|Map|Str|Math)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.mochi",
          "match": "\\b(float|int|string|bool|number)\\b"
        }
      ]
    },
    "constructors": {
      "patterns": [
        {
          "comment": "Uppercase-initial identifiers = variant constructors / types",
          "name": "entity.name.type.constructor.mochi",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mochi",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.mochi",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.mochi",
          "match": "=>"
        },
        {
          "name": "keyword.operator.bar.mochi",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.assignment.mochi",
          "match": "="
        },
        {
          "name": "punctuation.definition.sigil.mochi",
          "match": "[@#]"
        }
      ]
    }
  }
}
