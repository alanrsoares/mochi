{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "alang",
  "scopeName": "source.alang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#namespaces" },
    { "include": "#types" },
    { "include": "#constructors" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.alang",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.alang",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.alang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.alang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "let binding — highlight the bound name",
          "match": "\\b(let)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.alang" },
            "2": { "name": "entity.name.function.alang" }
          }
        },
        {
          "comment": "type declaration — highlight the type name",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.alang" },
            "2": { "name": "entity.name.type.alang" }
          }
        },
        {
          "comment": "extern declaration — highlight the external name",
          "match": "\\b(extern)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.alang" },
            "2": { "name": "entity.name.function.alang" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.alang",
          "match": "\\b(switch|import|export|in|when)\\b"
        },
        {
          "name": "keyword.declaration.alang",
          "match": "\\b(let|type|extern)\\b"
        }
      ]
    },
    "namespaces": {
      "patterns": [
        {
          "name": "support.class.namespace.alang",
          "match": "\\b(Array|List|Set|Map|Str|Math)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.alang",
          "match": "\\b(float|int|string|bool|number)\\b"
        }
      ]
    },
    "constructors": {
      "patterns": [
        {
          "comment": "Uppercase-initial identifiers = variant constructors / types",
          "name": "entity.name.type.constructor.alang",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.alang",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.alang",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.alang",
          "match": "=>"
        },
        {
          "name": "keyword.operator.bar.alang",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.assignment.alang",
          "match": "="
        },
        {
          "name": "punctuation.definition.sigil.alang",
          "match": "[@#]"
        }
      ]
    }
  }
}
