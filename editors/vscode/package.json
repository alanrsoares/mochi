{
  "name": "@mochi/vscode",
  "displayName": "mochi",
  "description": "Syntax highlighting for the mochi language (.mochi)",
  "version": "0.0.1",
  "publisher": "mochi",
  "private": true,
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": [],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "vscode-languageclient": "^10.1.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "mochi",
        "aliases": ["mochi", "Mochi"],
        "extensions": [".mochi"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mochi",
        "scopeName": "source.mochi",
        "path": "./syntaxes/mochi.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "mochi.restartLsp",
        "title": "mochi: Restart Language Server"
      }
    ]
  }
}
