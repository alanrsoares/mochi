{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": ["src/**/*.ts", "test/**/*.ts", "*.ts", "!src/runtime.ts"]
  },
  "javascript": { "globals": ["Bun"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 50 }
        }
      },
      "correctness": { "noUndeclaredVariables": "error", "useExhaustiveDependencies": "off" },
      "style": {
        "noNonNullAssertion": "off",
        "useConst": "error",
        "useImportType": "error",
        "noParameterAssign": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": { "level": "warn", "options": { "allow": ["error"] } }
      }
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "overrides": [
    {
      "includes": ["**", "!biome/plugins/**"],
      "plugins": [
        "./biome/plugins/no-promise-result.grit",
        "./biome/plugins/no-inline-struct-type.grit"
      ]
    },
    {
      "includes": ["**", "!test/**", "!**/*.spec.ts", "!biome/plugins/**"],
      "plugins": [
        "./biome/plugins/prefer-immutable-arrays.grit",
        "./biome/plugins/prefer-immutable-objects.grit"
      ]
    }
  ]
}
