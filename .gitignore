# dependencies (bun install)
node_modules

# output
out
dist
*.tgz

# Compiled `mochi build` output is always `.js`. Every source file is `.ts`,
# `.mochi`, or a hand-written/generated host runtime kept as `.mjs`, so all
# `.js` in the tree is a build artifact and safe to ignore wholesale.
*.js

# bootstrap `build --emit=ts` drops `.ts` / `.d.mts` beside the `.mochi` sources
# (JS emit is already covered by `*.js` above).
/bootstrap/*.ts
/bootstrap/*.d.mts

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# planning docs / issue tracker — kept local, not tracked
docs/plan/

# editor-local config (track shared agent rules/hooks only)
.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/hooks.json
!.cursor/hooks/
!.cursor/hooks/**

.serena/
.fixpoint-work/

# TS-backend differential test scratch (ADR 0026)
test/.tsgen/

# build --emit=ts differential scratch (ADR 0026)
test/.tsgen-graph/

# bootstrap-cli.spec.ts subprocess scratch (needs repo node_modules on the resolution path)
test/.mochi-cli-*/

.claude
